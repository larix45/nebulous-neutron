<style define:vars={{ciemny_braz, jasnoszary}}>
    .slide {
        width: 100%;
        color: aliceblue;
    }
    section {
        min-height: 30rem;
        background-color: var(--ciemny_braz);
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 1.8rem;
    }
    #slide-status {

    }
    #controls {
        display: flex;
        flex-direction: row;
        align-items: center;
        justify-content: center;
    }
    #card_opinie {
        background-color: var(--jasnoszary);
        color: rgb(0, 0, 0);
        padding: 1rem;
        border-radius: 0.5rem;
        max-width: clamp(20rem, 50%, 40rem);
        min-height: 14rem;
        display: flex;
        justify-content: center;
        align-items: center;
        flex-direction: column;
        margin-top: 2rem;
    }
</style>