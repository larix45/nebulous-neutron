<script>
    import Swiper from "swiper";
    import { Autoplay, Mousewheel, Navigation, Pagination } from "swiper/modules";

    new Swiper(".swiper", {
        modules: [Navigation, Pagination, Mousewheel, Autoplay],
        loop: true,
        centeredSlides:true,
        slidesPerView: 1,
        speed: 600,
        autoplay: {
            delay: 3000,
            disableOnInteraction: true,
        },
        spaceBetween: 10,
        pagination: { el: ".swiper-pagination", clickable: true },
        navigation: {
            nextEl: ".swiper-button-next",
            prevEl: ".swiper-button-prev",
        },
        grabCursor: true,
        effect: "flip",
        breakpoints: {
            480: {
                slidesPerView: 1,
            },
            600: {
                slidesPerView: "auto",
                slidesPerGroup: 1,
                spaceBetween: 5,
            },
            1200: {
                slidesPerView: 3,
                spaceBetween: 30,
            },

        }
    });
</script>

<style>
    .swiper {
        width: 100%;
        height: 100%;
        display: flex;
        flex-direction: column;
        --swiper-pagination-bullet-inactive-color: var(--color-text2);
        --swiper-pagination-color: var(--color-text2);
        --swiper-navigation-color: var(--color-text2);
    }
    .swiper-button-next {
        margin-right: 2.5rem;
    }
    .swiper-button-prev {
        margin-left: 2.5rem;
    }
    .swiper h3 {
        color: var(--color-text2);
        font-size: 1.6rem;
        align-self: center;
        font-weight: bolder;
    }
    .swiper-slide {
        display: flex;
        justify-content: center;
        align-items: center;
        margin-bottom: 2.5rem;
    }
    .swiper-pagination {
        margin-bottom: 0.1rem;
    }
    section {
        min-height: 30rem;
        background-color: var(--color-bg2);
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 1.8rem;
    }
    #card_opinie {
        background-color: var(--color-bg);
        color: var(--color-text);
        padding: 1rem;
        border-radius: 0.5rem;
        max-width: clamp(20rem, 50%, 40rem);
        min-height: 14rem;
        display: flex;
        justify-content: center;
        align-items: center;
        flex-direction: column;
        margin-top: 2rem;
    }
    @media screen and (max-width: 600px) {
        .swiper-button-prev, .swiper-button-next {
            display: none;
        }
    }
</style>
